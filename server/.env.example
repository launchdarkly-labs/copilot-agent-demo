PORT=3001

# LangChain universal init: "<provider>:<model>"
# Examples: "anthropic:claude-sonnet-4-6", "openai:gpt-4o-mini", "google-genai:gemini-1.5-pro"
MODEL_DEFAULT=anthropic:claude-sonnet-4-6
AI_CONFIG_CACHE_MS=30000

# Optional LaunchDarkly AI Config lookup. When configured, the server
# loads model + prompt settings from the LaunchDarkly AI Config below and
# falls back to MODEL_DEFAULT + the local system prompt if the lookup fails.
LD_PROJECT_KEY=copilot-agent-demo
LD_AI_CONFIG_KEY=launchdarkly-demo-chat
LD_ACCESS_TOKEN=api-...

# Provider keys — set the one matching MODEL above
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
